# Copy this file to .env at the repo root and fill in your values.
# The .env file is in .gitignore — never commit it.

# ─── Google Auth ───────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json
AUTH_MODE=oauth2                # oauth2 | service_account

# ─── Access Control ────────────────────────────────────────────────────────────
# Only the account whose email matches this value can use the server.
# Use your Google account email (e.g. the one you used in Google Cloud Console).
AUTHORIZED_USER_EMAIL=your-google-account@gmail.com

# ─── Server ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
MCP_TRANSPORT=stdio             # stdio | sse
MCP_HOST=127.0.0.1             # SSE only — never use 0.0.0.0
MCP_PORT=8000                   # SSE only
